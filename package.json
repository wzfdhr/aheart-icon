{
  "name": "@wzfdhr/aheart-icon",
  "version": "1.1.8",
  "description": "A tree-shakeable Vue 3 icon library with a searchable gallery",
  "scripts": {
    "svgo": "svgo -f ./icons -o ./icons",
    "generate:sfc": "npm run svgo && esno scripts/generate.ts",
    "docs:build": "esno scripts/generate-gallery.ts",
    "build:sfc": "esno scripts/build.ts",
    "build:types": "vue-tsc --declaration --emitDeclarationOnly",
    "build": "npm run generate:sfc && npm run build:sfc && npm run build:types",
    "prepack": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wzfdhr/aheart-icon.git"
  },
  "keywords": [
    "vue",
    "icons"
  ],
  "author": "Aheart",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "homepage": "https://wzfdhr.github.io/aheart-icon/",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "peerDependencies": {
    "vue": "^3.2.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^9.0.13",
    "chalk": "^5.0.1",
    "consola": "^2.15.3",
    "esbuild": "^0.14.39",
    "esbuild-plugin-globals": "^0.1.1",
    "esno": "^0.16.3",
    "fast-glob": "^3.2.11",
    "fs-extra": "^10.1.0",
    "rollup": "^2.74.1",
    "rollup-plugin-esbuild": "^4.9.1",
    "svgo": "^2.8.0",
    "typescript": "^4.6.4",
    "unplugin-vue": "^2.1.0",
    "vite": "^2.9.18",
    "vue": "^3.2.36",
    "vue-tsc": "^0.35.2"
  }
}
